# ─────────────────────────────────────────────
# Phoenix Med Tech – Lead Automation Bot
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# IndiaMART API
INDIAMART_API_KEY=your_indiamart_api_key_here
INDIAMART_MOBILE=your_registered_mobile_number   # e.g. 9876543210

# 360dialog WhatsApp
DIALOG360_API_KEY=your_360dialog_api_key
DIALOG360_WABA_ID=your_waba_id
WHATSAPP_FROM_NUMBER=your_whatsapp_number        # e.g. +60123456789

# AWS SES Email
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-1
SES_FROM_EMAIL=sales@phoenixmedtech.com
SES_FROM_NAME=Phoenix Med Tech

# Exotel Call Tracking
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_sid
EXOTEL_VIRTUAL_NUMBER=your_exotel_virtual_number # e.g. 08047xxxxxx
EXOTEL_CALLER_ID=your_exotel_caller_id

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Application Settings
LEAD_MIN_QUANTITY=300                            # Minimum boxes to qualify
POLL_INTERVAL_SECONDS=60                         # How often to check IndiaMART
APP_ENV=production                               # development | production
LOG_LEVEL=INFO

# Dashboard Auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_this_password

# Company Info (used in message templates)
COMPANY_NAME=Phoenix Med Tech (M) Sdn Bhd
COMPANY_PHONE=+60123456789
COMPANY_EMAIL=sales@phoenixmedtech.com
COMPANY_WEBSITE=https://www.phoenixmedtech.com
